APP_ENV=local
WEB_PORT=8080
FRONTEND_PORT=4173
WORKER_POLL_INTERVAL_SECS=2
WORKER_HEALTH_PORT=8081
WORKER_GAMEMASTER_PATH=./internal/pokemon.json
# Local fallback path used when DATABASE_URL is unset.
DATABASE_PATH=./var/app.db
# Deploy/Turso connection URL (required when APP_ENV is not local).
DATABASE_URL=
# Required for remote DATABASE_URL values (for example Turso).
DATABASE_AUTH_TOKEN=
# local: deterministic developer/test storage
# uploadthing: production media provider path (UPLOAD_LOCAL_DIR optional)
UPLOAD_STORAGE_MODE=local
# deterministic local path used by smoke checks and test fixtures
UPLOAD_LOCAL_DIR=./testdata/uploads
# Required when UPLOAD_STORAGE_MODE=uploadthing (web uploader auth).
UPLOADTHING_TOKEN=
# Optional UploadThing prepare-upload endpoint override.
UPLOADTHING_PREPARE_UPLOAD_URL=https://api.uploadthing.com/v7/prepareUpload
# HTTP timeout used by web UploadThing prepare/upload requests.
UPLOADTHING_REQUEST_TIMEOUT_SECS=30
# Worker download timeout for https upload URLs in uploadthing mode.
WORKER_UPLOADTHING_DOWNLOAD_TIMEOUT_SECS=30
# Worker retries for transient uploadthing media download failures.
WORKER_UPLOADTHING_DOWNLOAD_RETRY_COUNT=2
# Optional writable temp dir for worker uploadthing downloads (blank uses OS temp dir).
WORKER_UPLOADTHING_DOWNLOAD_TEMP_DIR=
# Frontend publishable key for Clerk React components. Use a real Clerk dev key locally.
VITE_CLERK_PUBLISHABLE_KEY=
# Enable Clerk bearer-token auth on the web API. Keep this true when validating signed-in flows locally.
CLERK_ENABLED=true
# Required when CLERK_ENABLED=true.
CLERK_SECRET_KEY=
# Required when CLERK_ENABLED=true. Comma-separated frontend origins that Clerk may issue tokens for.
CLERK_AUTHORIZED_PARTIES=http://127.0.0.1:4173,http://localhost:4173
# Optional full JWKS URL override used for Clerk session verification.
CLERK_JWKS_URL=
# Optional Better Stack Logs source token shared by web and worker.
BETTERSTACK_SOURCE_TOKEN=
# Better Stack ingesting host or full URL, e.g. https://in.logs.betterstack.com
BETTERSTACK_INGESTING_HOST=
# Optional comma-separated origins for browser CORS (defaults include localhost and 127.0.0.1 on FRONTEND_PORT and 5173)
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
